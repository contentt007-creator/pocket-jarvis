# MongoDB Atlas connection string (free tier at mongodb.com/atlas)
MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/pocket-jarvis?retryWrites=true&w=majority

# JWT secret for signing auth tokens (any long random string)
JWT_SECRET=change_this_to_a_long_random_string

# Google Gemini API key (free at aistudio.google.com)
GEMINI_API_KEY=AQ.Ab8RN6I...

# Server port
PORT=5000

# bKash PGW credentials (get from merchants.bkash.com — leave blank for manual TrxID mode)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true
BKASH_MERCHANT_NUMBER=01XXXXXXXXXX

# Public base URL of this backend (used in bKash callbacks)
API_BASE_URL=https://your-backend-url.up.railway.app

# Admin email — this user can approve manual bKash payments
ADMIN_EMAIL=your-admin@example.com

# Google Play Service Account JSON (single line, for IAP receipt validation)
# Get from Google Cloud Console → Service Accounts → JSON key
GOOGLE_SERVICE_ACCOUNT_JSON=
